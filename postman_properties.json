            "{{property_id}}",
            "save"
          ]
        }
      }
    },
    {
      "name": "Saved Properties",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "http://127.0.0.1:8000/api/properties/saved/",
