{
  "info": {
    "name": "TenantPlus Applications and Agreements API",
    "description": "Postman collection for testing application submission, landlord processing, agreement acknowledgment, and termination flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "tenant_access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "landlord_access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "property_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "application_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "agreement_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Applications",
      "item": [
        {
          "name": "List Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenant_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/applications/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "applications"
              ]
            },
            "description": "List applications visible to the authenticated user. Use a tenant token to see tenant applications or a landlord token to see applications for owned properties."
          }
        },
        {
          "name": "Create Application",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenant_access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"property\": \"{{property_id}}\",\n  \"message\": \"I am interested in this property and can move in next month.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/applications/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "applications"
              ]
            },
            "description": "Submit a new application as a tenant."
          }
        },
        {
          "name": "Get Application Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenant_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/applications/{{application_id}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "applications",
                "{{application_id}}"
              ]
            },
            "description": "Retrieve a single application as the tenant or the property owner landlord."
          }
        },
        {
          "name": "Accept Application",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"accepted\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/applications/{{application_id}}/status/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "applications",
                "{{application_id}}",
                "status"
              ]
            },
            "description": "Accept an application as the owning landlord. This should create an agreement automatically."
          }
        },
        {
          "name": "Reject Application",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"rejected\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/applications/{{application_id}}/status/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "applications",
                "{{application_id}}",
                "status"
              ]
            },
            "description": "Reject an application as the owning landlord."
          }
        },
        {
          "name": "Withdraw Application",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenant_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/applications/{{application_id}}/withdraw/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "applications",
                "{{application_id}}",
                "withdraw"
              ]
            },
            "description": "Withdraw a pending application as the tenant who submitted it."
          }
        }
      ]
    },
    {
      "name": "Agreements",
      "item": [
        {
          "name": "List Agreements",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenant_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/agreements/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "agreements"
              ]
            },
            "description": "List agreements visible to the authenticated user. Use a tenant token to see tenant agreements or a landlord token to see landlord agreements."
          }
        },
        {
          "name": "Get Agreement Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenant_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/agreements/{{agreement_id}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "agreements",
                "{{agreement_id}}"
              ]
            },
            "description": "Retrieve a single agreement as either the tenant or landlord."
          }
        },
        {
          "name": "Acknowledge Agreement as Tenant",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenant_access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/agreements/{{agreement_id}}/acknowledge/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "agreements",
                "{{agreement_id}}",
                "acknowledge"
              ]
            },
            "description": "Mark the agreement acknowledged as the tenant."
          }
        },
        {
          "name": "Acknowledge Agreement as Landlord",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/agreements/{{agreement_id}}/acknowledge/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "agreements",
                "{{agreement_id}}",
                "acknowledge"
              ]
            },
            "description": "Mark the agreement acknowledged as the landlord."
          }
        },
        {
          "name": "Terminate Agreement",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenant_access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"termination_reason\": \"Tenant is moving out at the end of the month.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/agreements/{{agreement_id}}/terminate/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "agreements",
                "{{agreement_id}}",
                "terminate"
              ]
            },
            "description": "Terminate an active agreement as either the tenant or landlord."
          }
        }
      ]
    }
  ]
}