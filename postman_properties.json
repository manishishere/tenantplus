{
  "info": {
    "name": "TenantPlus Properties API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "List Properties",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://127.0.0.1:8000/api/properties/",
          "host": [
            "http://127.0.0.1:8000"
          ],
          "path": [
            "api",
            "properties"
          ]
        }
      }
    },
    {
      "name": "Create Property",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Cozy Studio Apartment\",\n  \"description\": \"A bright studio near the city center\",\n  \"district\": \"Kathmandu\",\n  \"address\": \"123 Main Street\",\n  \"room_type\": \"flat\",\n  \"furnishing_status\": \"furnished\",\n  \"rent_amount\": \"18000.00\"\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:8000/api/properties/",
          "host": [
            "http://127.0.0.1:8000"
          ],
          "path": [
            "api",
            "properties"
          ]
        }
      }
    },
    {
      "name": "Get Property Detail",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://127.0.0.1:8000/api/properties/{{property_id}}/",
          "host": [
            "http://127.0.0.1:8000"
          ],
          "path": [
            "api",
            "properties",
            "{{property_id}}"
          ]
        }
      }
    },
    {
      "name": "Update Property",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Updated Cozy Studio Apartment\",\n  \"description\": \"Updated description\",\n  \"district\": \"Kathmandu\",\n  \"address\": \"123 Main Street\",\n  \"room_type\": \"flat\",\n  \"furnishing_status\": \"semi_furnished\",\n  \"rent_amount\": \"20000.00\"\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:8000/api/properties/{{property_id}}/",
          "host": [
            "http://127.0.0.1:8000"
          ],
          "path": [
            "api",
            "properties",
            "{{property_id}}"
          ]
        }
      }
    },
