            "my-listings"
          ]
        }
      }
    },
    {
      "name": "Toggle Availability",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "http://127.0.0.1:8000/api/properties/{{property_id}}/toggle-availability/",
          "host": [
            "http://127.0.0.1:8000"
          ],
          "path": [
            "api",
            "properties",
            "{{property_id}}",
            "toggle-availability"
