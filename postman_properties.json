      "name": "Upload Photo",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"photo_url\": \"https://example.com/photo.jpg\",\n  \"sort_order\": 1\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:8000/api/properties/{{property_id}}/photos/",
